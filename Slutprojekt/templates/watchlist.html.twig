{% extends "base.html.twig" %}

{% block main %}

  
{% if username %}  
    <h1>Your watchlist</h1>
    <table>
        <tr>
            <th>Movies</th>
            <th>Date Added</th>
            <th>Remove</th>
        </tr>
    {% for item in watchlist %}
        <tr>
            <td> <a href="{{url("info.php")}}?MovieId={{ item.MovieId }}&genre={{item.Genre}}">{{ item.Title }}</a></td>
            <td>{{item.DateAdded }}</td>
            <td>
                <form action="delete-watchlist-formhandler.php" method="post" class="remove-watchlistform">
                <input type="hidden" name="MovieId" value="{{ item.MovieId }}">
                <button type="submit" class="watchlistbtn-remove">Remove</button>
                </form>
            </td>
        </tr>
    {% endfor %}
    </table>
{% endif %}
    
{% if not username %}  
    <h1>Log in to access your watchlist</h1>
{% endif %}

{% endblock %}