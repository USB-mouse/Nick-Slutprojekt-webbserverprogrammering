{% extends "base.html.twig" %}
{% block main %}



{% for item in movies %}
  <h1> {{item.Title}} </h1> 
{% endfor %}


<div class="MainInfo">
{% for item in movies %}
      <div class="movie-poster">
            <img src="images/{{ item.Cover }}" alt="{{ item.Title }}">
            </div>
  
            

{% endfor %}

 <div class="tableandsummery">

 <table>          
        <tr>
            <th>ReleaseYear</th>
            <th>Genre</th>
            <th>Director</th>
        </tr>
    {% for item in movies %}
<div class="summery">
<h4> Summery</h4>
{{ item.Summery}}
</div>
        <tr> 
            <td>  {{ item.ReleaseYear }}</td> 
            <td> <a href="{{url("Allmovies.php")}}?genre={{ item.Genre}}"> {{ item.Genre}}</a></td>
            <td>    {{item.Director}}</td>
        </tr>   
       
      {% endfor %}
        </table>
        </div>
</div>


       <h3 class="action"> <a href="{{url("review/review.php")}}?MovieId={{ MovieId }}" class="review-button">reviews</a> </h3>


    {% if not username %}  
      Logga in för att lägga till watchlist 
     {% endif %}
    
     {% if username %}  
        <form action="watchlist/watchlist-formhandler.php?MovieId={{MovieId}}" class="watchlist-button"  method="post">
        <input type="hidden" name="MovieId" value="{{ MovieId }}">
        <input type="hidden" name="UserId" value="{{ UserId }}">
         <input type="hidden" name="genre" value="{{ genre }}">
        <input type="submit" value="Add to watchlist">
  </form>

     {% endif %}

     <div class="LiknadeFilmer">
<h4>Liknade filmer</h4>
<table>          
        <tr>
            <th>Title</th>
            <th>ReleaseYear</th>
            <th>Genre</th>
        </tr>
    {% for item in Lkmovies %}


</div>
        <tr> 
            <td> <a href="{{url("info.php")}}?MovieId={{ item.MovieId }}&genre={{item.Genre}}">{{ item.Title }}</a></td>
            <td>  {{ item.ReleaseYear }}</td> 
            <td> <a href="{{url("Allmovies.php")}}?genre={{ item.Genre}}"> {{ item.Genre}}</a></td>
        </tr>   
       
      {% endfor %}
        </table>
     </div>
 
{% endblock %}



    
            
          
    