{% extends "base.html.twig" %}
{% block main %}




    <a href="movies.php?sort=newest">Senast tillagda</a>
    <a href="movies.php?sort=al">A-Ö</a>
    <a href="movies.php">Visa alla (standard)</a>
 <h2>Upptäck filmer</h2>
    <h1>Newest additons</h1>
   
<table>
        <tr>
            <th>Newest additons</th>
        </tr>
{% for item in newest %}
        <tr>
            <td> <a href="{{url("info.php")}}?MovieId={{ item.MovieId }}">{{ item.Title }}</a></td>
              <td>{{item.MovieDateAdded }}</td>
        </tr>
  {% endfor %}
    </table>
<h1>Best scores</h1>

<h1>Most reviews</h1>

<h1>Movies</h1>
  <table>
        <tr>
            <th>Movies</th>
        </tr>
{% for item in movies %}
        <tr>
            <td> <a href="{{url("info.php")}}?MovieId={{ item.MovieId }}">{{ item.Title }}</a></td>
        </tr>
  {% endfor %}
    </table>


    
     <h1>Your watchlist</h1>
      {% if username %}  


    <table>
        <tr>
            <th>Movies</th>
        </tr>
{% for item in watchlist %}
        <tr>
             <td> <a href="{{url("info.php")}}?MovieId={{ item.MovieId }}">{{ item.Title }}</a></td>
            <td>{{item.DateAdded | date("d/m-Y H:i") }}</td>
        </tr>
  {% endfor %}
    </table>
     {% endif %}
    {% if not username %}  
         <h3>Log in to access</h3>
     {% endif %}






{% endblock %}
 
  

